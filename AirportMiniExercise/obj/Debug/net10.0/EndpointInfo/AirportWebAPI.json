        ],
        "parameters": [
          {
            "name": "flightNumber",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDeparture"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDeparture"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDeparture"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FlightDeparture": {
        "type": "object",
        "properties": {
          "flightNumber": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "distination": {
            "type": [
              "null",
              "string"
            ]
          },
          "departureTime": {
            "type": "string",
            "format": "time"
          },
          "gate": {
            "type": [
              "null",
              "string"
            ]
          },
          "state": {
            "$ref": "#/components/schemas/Status"
          }
        }
      },
      "Status": {
        "type": "integer"
      }
    }
  },
  "tags": [
    {
      "name": "Flight"
    }
  ]
}