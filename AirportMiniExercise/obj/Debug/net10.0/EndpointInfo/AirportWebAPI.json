              "schema": {
                "$ref": "#/components/schemas/FlightDeparture"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/FlightDeparture"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/FlightDeparture"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDeparture"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDeparture"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightDeparture"
                }
              }
            }
          }
        }
      }
    },
